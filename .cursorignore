# Exclusions for Cursor indexing (see AGENTS.md — Cursor IDE).
# Patterns follow .gitignore semantics: security-sensitive paths, local overrides,
# and large or generated trees that add little value to AI context.

# Environment and secrets (never index)
.env
.env.*
!.env.example
secrets/

# Local-only tool overrides
.claude/settings.local.json

# Dependencies and caches (large / noisy)
node_modules/
.pnpm-store/
.npm-cache/
.npm/
.yarn/cache
.eslintcache
.stylelintcache
*.tsbuildinfo

# Build, coverage, and reports
coverage/
.nyc_output/
*.lcov
dist/
.next/
out/
.nuxt/
.serverless/
.docusaurus/
**/.vitepress/dist
**/.vitepress/cache
.svelte-kit/
build/Release/
lint-report.json
coverage-report.json

# Logs and diagnostics
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Security / analysis tooling output
codeql-db/
codeql-results.sarif

# Playwright and E2E artifacts
test-results/
playwright-report/
playwright/.cache/

# Git worktrees and scratch
.worktrees/

# Vite timestamp sidecars
vite.config.js.timestamp-*
vite.config.ts.timestamp-*
