{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignoreBinaries": ["codeql", "prettier", "trunk", "semgrep"],
  "ignoreExportsUsedInFile": true,
  "ignoreIssues": {
    "packages/dbt-artifacts-parser/**/*.ts": ["types"]
  },
  "workspaces": {
    ".": {
      "entry": ["scripts/**/*.mjs"],
      "project": ["scripts/**/*.mjs"],
      "vitest": {
        "config": ["vitest.config.mjs", "vitest.coverage.mjs"],
        "entry": ["packages/**/*.test.ts"]
      }
    },
    "packages/dbt-artifacts-parser": {
      "project": ["src/**/*.ts", "scripts/**/*.js"],
      "ignoreFiles": ["scripts/preprocess-refs.js"],
      "ignoreDependencies": ["@apidevtools/json-schema-ref-parser"]
    }
  }
}
