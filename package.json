{
  "name": "dbt-artifacts-parser",
  "version": "0.2.0",
  "private": true,
  "description": "A community-driven TypeScript library for parsing dbt artifacts with full type safety and automatic version detection.",
  "keywords": [],
  "license": "Apache-2.0",
  "author": "yu-iskw",
  "main": "index.js",
  "scripts": {
    "build": "pnpm --recursive build",
    "codeql": "pnpm codeql:db && pnpm codeql:analyze",
    "codeql:analyze": "node scripts/codeql-check.mjs && codeql database analyze ./codeql-db codeql/javascript-queries --download --format=sarif-latest --output=codeql-results.sarif",
    "codeql:db": "node scripts/codeql-check.mjs && rm -rf ./codeql-db && codeql database create ./codeql-db --language=javascript --source-root=.",
    "coverage:report": "node scripts/coverage-score.mjs",
    "format": "pnpm format:trunk",
    "format:all": "pnpm format:trunk-all",
    "format:eslint": "eslint . --fix",
    "format:prettier": "prettier --write .",
    "format:trunk": "trunk fmt",
    "format:trunk-all": "trunk fmt --all",
    "json2ts": "./node_modules/.bin/json2ts",
    "lint": "pnpm lint:trunk && pnpm lint:eslint",
    "lint:all": "pnpm lint:trunk-all",
    "lint:eslint": "eslint .",
    "lint:report": "node scripts/eslint-score.mjs",
    "lint:security": "trunk check --all --scope security -y",
    "lint:semgrep": "semgrep ci",
    "lint:trunk": "trunk check -y",
    "lint:trunk-all": "trunk check --all -y",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@apidevtools/json-schema-ref-parser": "^15.3.1",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/eslint-plugin": "^1.6.11",
    "eslint": "^10.0.3",
    "eslint-plugin-sonarjs": "^4.0.2",
    "json-schema-to-typescript": "^15.0.4",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  },
  "pnpm": {
    "overrides": {
      "esbuild": "^0.27.2",
      "lodash": "^4.17.23",
      "rollup": ">=4.59.0"
    }
  }
}
