{
  "name": "dbt-artifacts-parser",
  "version": "0.5.2",
  "private": true,
  "description": "A community-driven TypeScript library for parsing dbt artifacts with full type safety and automatic version detection.",
  "keywords": [],
  "license": "SEE LICENSE IN LICENSE",
  "author": "yu-iskw",
  "scripts": {
    "build": "pnpm --recursive --sequential run build",
    "clean": "rm -rf ./packages/dbt-tools/web/dist ./packages/dbt-tools/web/dist-serve ./packages/dbt-tools/web/playwright-report ./packages/dbt-tools/web/test-results",
    "codeql": "pnpm codeql:db && pnpm codeql:analyze",
    "codeql:analyze": "node scripts/codeql-check.mjs codeql/javascript-queries && codeql database analyze ./codeql-db codeql/javascript-queries --format=sarif-latest --output=codeql-results.sarif",
    "codeql:analyze:download": "node scripts/codeql-check.mjs && codeql database analyze ./codeql-db codeql/javascript-queries --download --format=sarif-latest --output=codeql-results.sarif",
    "codeql:clean": "pnpm clean && rm -rf ./codeql-db ./codeql-results.sarif",
    "codeql:db": "node scripts/codeql-check.mjs && pnpm codeql:clean && codeql database create ./codeql-db --language=javascript --source-root=.",
    "coverage:report": "node scripts/coverage-score.mjs",
    "tokens:sync": "node scripts/sync-css-tokens-to-ts.mjs && prettier --write packages/dbt-tools/web/src/constants/themeColors.generated.ts",
    "tokens:check": "pnpm tokens:sync && git diff --exit-code packages/dbt-tools/web/src/constants/themeColors.generated.ts",
    "dev:web": "pnpm --filter @dbt-tools/web dev",
    "format": "pnpm format:trunk && pnpm format:eslint && pnpm format:prettier",
    "format:all": "pnpm format:trunk-all",
    "format:eslint": "eslint . --fix",
    "format:prettier": "prettier --write .",
    "format:trunk": "trunk fmt",
    "format:trunk-all": "trunk fmt --all",
    "format:without-trunk": "pnpm format:eslint && pnpm format:prettier",
    "json2ts": "./node_modules/.bin/json2ts",
    "lint": "pnpm lint:trunk && pnpm lint:eslint && pnpm lint:stylelint && pnpm knip",
    "lint:without-trunk": "pnpm lint:eslint && pnpm lint:stylelint && pnpm knip",
    "lint:all": "pnpm lint:trunk-all",
    "lint:eslint": "eslint .",
    "lint:stylelint": "stylelint \"packages/dbt-tools/web/src/**/*.css\"",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "lint:knip": "knip",
    "lint:report": "node scripts/eslint-score.mjs",
    "lint:security": "trunk check --all --scope security -y",
    "lint:semgrep": "semgrep ci",
    "lint:trunk": "trunk check -y",
    "lint:trunk-all": "trunk check --all -y",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "pnpm --filter @dbt-tools/web test:e2e",
    "verify:normalize": "pnpm format && pnpm lint"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/eslint-plugin": "^1.6.14",
    "eslint": "^10.2.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-sonarjs": "^4.0.2",
    "jsdom": "^29.0.1",
    "json-schema-to-typescript": "^15.0.4",
    "knip": "^6.3.0",
    "stylelint": "^17.6.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-declaration-strict-value": "^1.11.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "pnpm": {
    "overrides": {
      "@tootallnate/once": "^3.0.1",
      "esbuild": "^0.27.2",
      "flatted": ">=3.4.2",
      "lodash": "^4.18.0",
      "rollup": ">=4.59.0"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "typescript": "6",
        "eslint-plugin-jsx-a11y>eslint": "10",
        "eslint-plugin-react>eslint": "10",
        "eslint-plugin-react-hooks>eslint": "10"
      }
    }
  }
}
