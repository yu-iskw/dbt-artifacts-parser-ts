{
  "name": "dbt-artifacts-parser",
  "version": "0.2.0",
  "description": "TypeScript library for parsing dbt artifacts",
  "keywords": [],
  "license": "ISC",
  "author": "",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./manifest": {
      "types": "./dist/manifest/index.d.ts",
      "default": "./dist/manifest/index.js"
    },
    "./run_results": {
      "types": "./dist/run_results/index.d.ts",
      "default": "./dist/run_results/index.js"
    },
    "./catalog": {
      "types": "./dist/catalog/index.d.ts",
      "default": "./dist/catalog/index.js"
    },
    "./sources": {
      "types": "./dist/sources/index.d.ts",
      "default": "./dist/sources/index.js"
    },
    "./test-utils": {
      "types": "./dist/test-utils.d.ts",
      "default": "./dist/test-utils.js"
    }
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "gen:types": "bash scripts/generate.sh",
    "prepack": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@apidevtools/json-schema-ref-parser": "^15.3.1",
    "@types/node": "^25.5.0",
    "vitest": "^4.1.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
