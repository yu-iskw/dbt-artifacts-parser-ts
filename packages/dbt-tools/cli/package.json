{
  "name": "@dbt-tools/cli",
  "version": "0.4.3",
  "description": "Command-line interface for dbt artifact analysis",
  "keywords": [
    "dbt",
    "cli",
    "analysis"
  ],
  "license": "SEE LICENSE IN LICENSE",
  "author": "yu-iskw",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "dbt-tools": "./dist/cli.js"
  },
  "files": [
