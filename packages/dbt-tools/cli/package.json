{
  "name": "@dbt-tools/cli",
  "version": "0.1.0",
  "description": "Command-line interface for dbt artifact analysis",
  "keywords": [
    "dbt",
    "cli",
    "analysis"
  ],
  "license": "Apache-2.0",
  "author": "yu-iskw",
  "bin": {
    "dbt-tools": "./dist/cli.js"
  },
  "files": [
    "dist",
    "public",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "build:full": "pnpm --filter @dbt-tools/web build && cp -r ../web/dist ./public && tsc",
    "prepack": "npm run build",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@dbt-tools/core": "workspace:*",
    "chokidar": "^4.0.3",
    "commander": "^14.0.3",
    "dbt-artifacts-parser": "workspace:*",
    "express": "^4.21.2",
    "graphology": "^0.26.0",
    "ws": "^8.18.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "@types/node": "^25.5.0",
    "@types/ws": "^8.5.14",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
