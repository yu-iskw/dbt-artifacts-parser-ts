{
  "compilerOptions": {
    "target": "es2017",
    "module": "Node16",
    "moduleResolution": "node16",
    "lib": ["es2017"],
    "types": ["node"],
    "declaration": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src"],
  "exclude": ["src/**/*.test.ts"]
}
