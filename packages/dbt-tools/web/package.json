{
  "name": "@dbt-tools/web",
  "version": "0.3.9",
  "description": "Web application for visual dbt artifact analysis",
  "keywords": [
    "dbt",
    "web",
    "visualization"
  ],
  "license": "Apache-2.0",
  "author": "yu-iskw",
  "type": "module",
  "bin": {
    "dbt-tools-web": "./dist-serve/server/cli.js"
  },
  "files": [
    "dist",
    "dist-serve",
    "README.md"
  ],
  "scripts": {
    "prepack": "npm run build",
    "build": "pnpm --filter @dbt-tools/core build && tsc && vite build && pnpm run build:serve",
    "build:serve": "vite build --config vite.server.config.ts --ssr src/server/cli.ts",
    "dev": "vite",
    "dev:debug": "DBT_TOOLS_DEBUG=1 vite",
    "dev:target": "DBT_TOOLS_TARGET_DIR=./target vite",
    "preview": "vite preview",
    "test:e2e": "pnpm build && playwright test",
    "lint": "pnpm lint:eslint && pnpm lint:stylelint",
    "lint:eslint": "eslint ../../../eslint.config.mjs",
    "lint:stylelint": "stylelint -c ../../../stylelint.config.mjs **/*.css",
    "format:stylelint": "stylelint -c ../../../stylelint.config.mjs **/*.css --fix"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1019.0",
    "@dbt-tools/core": "workspace:*",
    "@google-cloud/storage": "^7.19.0",
    "@tanstack/react-virtual": "^3.13.23",
    "dbt-artifacts-parser": "workspace:*",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
