{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$description": "Foundation design tokens — raw scales consumed by semantic and component layers. Single source of truth; tokens.css is the CSS output.",

  "palette": {
    "$description": "Raw color palette. Use semantic tokens in components, not these directly.",
    "white": "#ffffff",
    "black": "#000000",
    "slate": {
      "50": "#f8fafc",
      "100": "#f1f5f9",
      "200": "#e2e8f0",
      "300": "#cbd5e1",
      "400": "#94a3b8",
      "500": "#64748b",
      "600": "#475569",
      "700": "#334155",
      "800": "#1e293b",
      "900": "#0f172a",
      "950": "#020617"
    },
    "indigo": {
      "50": "#eef2ff",
      "100": "#e0e7ff",
      "200": "#c7d2fe",
      "300": "#a5b4fc",
      "400": "#818cf8",
      "500": "#6366f1",
      "600": "#4f46e5",
      "700": "#4338ca"
    },
    "violet": {
      "400": "#a78bfa",
      "500": "#8b5cf6",
      "600": "#7c3aed"
    },
    "brand": {
      "primary": "#635bff",
      "primaryHover": "#554ceb",
      "primaryActive": "#473ed0",
      "primarySoft": "#eef0ff",
      "focusRing": "#6d5ef7"
    },
    "green": {
      "500": "#0f8a4b",
      "soft": "#eaf8f0"
    },
    "amber": {
      "500": "#a56315",
      "soft": "#fff5e8"
    },
    "red": {
      "500": "#c0352b",
      "soft": "#fdedec"
    },
    "blue": {
      "500": "#1769e0",
      "soft": "#eaf2ff"
    }
  },

  "spacing": {
    "$description": "Spacing scale in rem. Use --space-{n} custom properties.",
    "0": "0",
    "px": "1px",
    "05": "0.125rem",
    "1": "0.25rem",
    "15": "0.375rem",
    "2": "0.5rem",
    "25": "0.625rem",
    "3": "0.75rem",
    "4": "1rem",
    "5": "1.25rem",
    "6": "1.5rem",
    "8": "2rem",
    "10": "2.5rem",
    "12": "3rem",
    "16": "4rem",
    "20": "5rem",
    "24": "6rem",
    "32": "8rem"
  },

  "typography": {
    "$description": "Type scale and line-heights.",
    "fontSize": {
      "xs": "0.75rem",
      "sm": "0.875rem",
      "base": "1rem",
      "lg": "1.125rem",
      "xl": "1.25rem",
      "2xl": "1.5rem",
      "3xl": "1.875rem"
    },
    "lineHeight": {
      "tight": "1.2",
      "snug": "1.35",
      "normal": "1.5",
      "relaxed": "1.65"
    },
    "fontWeight": {
      "normal": "400",
      "medium": "500",
      "semibold": "600",
      "bold": "700"
    },
    "fontFamily": {
      "sans": "\"IBM Plex Sans\", \"Avenir Next\", \"Segoe UI\", sans-serif",
      "mono": "\"IBM Plex Mono\", SFMono-Regular, Consolas, monospace",
      "display": "\"Space Grotesk\", \"IBM Plex Sans\", sans-serif"
    }
  },

  "radii": {
    "xs": "4px",
    "sm": "8px",
    "md": "12px",
    "lg": "16px",
    "full": "9999px"
  },

  "shadows": {
    "sm": "0 1px 2px rgb(15 15 35 / 5%)",
    "md": "0 1px 3px rgb(15 15 35 / 6%), 0 4px 12px rgb(15 15 35 / 4%)",
    "lg": "0 4px 24px rgb(0 0 0 / 12%)",
    "xl": "0 8px 32px rgb(0 0 0 / 16%)"
  },

  "motion": {
    "duration": {
      "fast": "120ms",
      "normal": "200ms",
      "slow": "350ms"
    },
    "easing": {
      "default": "cubic-bezier(0.4, 0, 0.2, 1)",
      "in": "cubic-bezier(0.4, 0, 1, 1)",
      "out": "cubic-bezier(0, 0, 0.2, 1)",
      "spring": "cubic-bezier(0.16, 1, 0.3, 1)"
    }
  },

  "zIndex": {
    "dropdown": "100",
    "sticky": "200",
    "tooltip": "300",
    "overlay": "400",
    "modal": "450",
    "toast": "500"
  },

  "breakpoints": {
    "$description": "CSS custom properties cannot be used in media queries; these are documented here as canonical values.",
    "sm": "480px",
    "md": "640px",
    "lg": "780px",
    "xl": "1024px",
    "2xl": "1180px"
  }
}
