{
  "fontFamily": {
    "sans": {
      "$type": "fontFamily",
      "$value": ["IBM Plex Sans", "Avenir Next", "Segoe UI", "sans-serif"]
    },
    "mono": {
      "$type": "fontFamily",
      "$value": ["IBM Plex Mono", "SFMono-Regular", "Consolas", "monospace"]
    }
  },
  "fontSize": {
    "2xs": { "$type": "dimension", "$value": "0.72rem" },
    "xs": { "$type": "dimension", "$value": "0.78rem" },
    "sm": { "$type": "dimension", "$value": "0.82rem" },
    "md": { "$type": "dimension", "$value": "0.875rem" },
    "lg": { "$type": "dimension", "$value": "1rem" },
    "xl": { "$type": "dimension", "$value": "1.125rem" }
  },
  "fontWeight": {
    "regular": { "$type": "fontWeight", "$value": "400" },
    "medium": { "$type": "fontWeight", "$value": "500" },
    "semibold": { "$type": "fontWeight", "$value": "600" }
  },
  "lineHeight": {
    "tight": { "$type": "number", "$value": 1.25 },
    "snug": { "$type": "number", "$value": 1.35 },
    "normal": { "$type": "number", "$value": 1.45 },
    "relaxed": { "$type": "number", "$value": 1.5 }
  }
}
