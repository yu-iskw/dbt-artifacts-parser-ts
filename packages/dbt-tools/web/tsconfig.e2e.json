{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": [
    "e2e/**/*",
    "playwright.config.ts",
    "playwright.capture.config.ts",
    "scripts/**/*.ts"
  ]
}
